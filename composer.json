{
    "name": "taochangle/matrix-framework",
    "type": "library",
    "description": "Matrix - A modern PHP micro-framework",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "symfony/http-foundation": "^6.0|^7.0",
        "nikic/fast-route": "^1.3",
        "php-di/php-di": "^7.0",
        "illuminate/database": "^10.0|^11.0",
        "robmorgan/phinx": "^0.16",
        "firebase/php-jwt": "^6.0",
        "symfony/var-dumper": "^6.0|^7.0",
        "spatie/ignition": "^1.0",
        "maximebf/debugbar": "^1.18",
        "twig/twig": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Matrix\\": "src/"
        }
    },
    "config": {
        "audit": {
            "ignore": ["PKSA-y2cr-5h3j-g3ys"]
        }
    }
